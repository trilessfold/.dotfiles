#!/usr/bin/env python3

import requests
import time
import base64

GITLAB_URL = "https://gitlab.eltex.loc"
TOKEN = "TOKEN"

SEARCH_STRING = "ecss/ecss-toolchain-lib"

HEADERS = {
    "PRIVATE-TOKEN": TOKEN
}

def get_all_projects():
    projects = []
    page = 1

    while True:
        resp = requests.get(
            f"{GITLAB_URL}/api/v4/projects",
            headers=HEADERS,
            params={
                "membership": "true",
                "per_page": 100,
                "page": page
            }
        )
        resp.raise_for_status()

        data = resp.json()
        if not data:
            break

        projects.extend(data)
        page += 1

    return projects


def get_gitlab_ci_content(project_id, ref):
    resp = requests.get(
        f"{GITLAB_URL}/api/v4/projects/{project_id}/repository/files/.gitlab-ci.yml",
        headers=HEADERS,
        params={"ref": ref}
    )

    if resp.status_code != 200:
        return None

    content_base64 = resp.json()["content"]
    return base64.b64decode(content_base64).decode("utf-8", errors="ignore")

def get_last_tag(project_id):
    resp = requests.get(
        f"{GITLAB_URL}/api/v4/projects/{project_id}/repository/tags",
        headers=HEADERS,
        params={"per_page": 1, "order_by": "updated", "sort": "desc"}
    )
    if resp.status_code != 200:
        return None

    tags = resp.json()
    if not tags:
        return None

    return tags[0]["name"]

def main():
    projects = get_all_projects()

    for project in projects:
        project_id = project["id"]
        project_name = project["path_with_namespace"]
        default_branch = project["default_branch"]

        if not default_branch:
            continue

        ci_content = get_gitlab_ci_content(project_id, default_branch)
        if not ci_content:
            continue

        if SEARCH_STRING in ci_content:
            last_tag = get_last_tag(project_id) or "NO_TAGS"
            print(f"{project_id} | {project_name} | {last_tag}")
        time.sleep(0.05)  # защита от rate limit


if __name__ == "__main__":
    main()

